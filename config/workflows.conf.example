# Workflows requeridos para certificar origin/dev@SHA.
# Copia este archivo a .devtools/config/workflows.conf en el repo consumidor.

# Lista mínima obligatoria para gate en promote dev.
REQUIRED_WORKFLOWS_DEV=("ci.yaml")

# Opcional por entorno:
# - Si defines REQUIRED_WORKFLOWS_STAGING/PROD/HOTFIX con valores, se usan para ese scope.
# - Si no existen o están vacíos, el gate hace fallback a REQUIRED_WORKFLOWS_DEV.
# REQUIRED_WORKFLOWS_STAGING=("release-please.yaml")
# REQUIRED_WORKFLOWS_PROD=("release-please.yaml")
# REQUIRED_WORKFLOWS_HOTFIX=("release-please.yaml")

# Gate exclusivo de promote local (branches locales / e2e local).
# Vacío => promote local no bloquea por workflows remotos.
REQUIRED_WORKFLOWS_LOCAL=()
