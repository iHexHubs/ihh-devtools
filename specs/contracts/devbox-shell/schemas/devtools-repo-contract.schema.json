{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "specs/contracts/devbox-shell/schemas/devtools-repo-contract.schema.json",
  "title": "Relevant Devtools Repo Contract Fields",
  "type": "object",
  "required": [
    "schema_version",
    "paths",
    "config"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "paths": {
      "type": "object",
      "required": [
        "vendor_dir"
      ],
      "properties": {
        "vendor_dir": {
          "type": "string",
          "const": ".devtools"
        }
      },
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "required": [
        "profile_file"
      ],
      "properties": {
        "profile_file": {
          "type": "string",
          "const": ".git-acprc"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
