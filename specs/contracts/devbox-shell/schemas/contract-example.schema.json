{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "specs/contracts/devbox-shell/schemas/contract-example.schema.json",
  "title": "Devbox Shell Contract Example",
  "type": "object",
  "required": [
    "scenario_id",
    "consumer",
    "command",
    "expected_contractual_observables"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "consumer": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "expected_contractual_observables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
